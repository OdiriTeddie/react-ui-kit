{
  "name": "react-ui-kit",
  "version": "0.1.0",
  "description": "Enterprise-ready React UI components for building data-heavy applications.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "author": "OdiriTeddie",
  "homepage": "https://github.com/OdiriTeddie/react-ui-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OdiriTeddie/react-ui-kit.git"
  },
  "bugs": {
    "url": "https://github.com/OdiriTeddie/react-ui-kit/issues"
  },
  "keywords": [
    "react",
    "typescript",
    "ui-kit",
    "data-grid",
    "enterprise",
    "components"
  ],
  "main": "./dist/react-ui-kit.umd.cjs",
  "module": "./dist/react-ui-kit.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/react-ui-kit.js",
      "require": "./dist/react-ui-kit.umd.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.lib.json && vite build",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
